# API Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
REQUEST_BODY_LIMIT=2mb

# API Authentication (required for /v1)
# Comma-separated API keys accepted in Authorization: Bearer <key>
API_AUTH_KEYS=dev-local-key-1,dev-local-key-2

# Rate limiting per API key
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# CORS (use * or comma-separated origins)
ALLOWED_ORIGINS=*

# Google Gemini Configuration (FREE tier available)
# Get key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key
GEMINI_MAX_REQUESTS_PER_MINUTE=1000
GEMINI_MAX_TOKENS_PER_MINUTE=32000
GEMINI_ENABLED=true

# Groq Configuration (FREE tier available)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key
GROQ_MAX_REQUESTS_PER_MINUTE=3000
GROQ_MAX_TOKENS_PER_MINUTE=60000
GROQ_ENABLED=true

# SambaNova Cloud Configuration (FREE tier available)
# Get key at: https://cloud.sambanova.ai/
SAMBANOVA_API_KEY=your_sambanova_key
SAMBANOVA_ENABLED=true
SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct

# Cerebras Configuration (FREE tier available)
# Get key at: https://www.cerebras.ai/
CEREBRAS_API_KEY=your_cerebras_key
CEREBRAS_ENABLED=true
CEREBRAS_MODEL=llama-3.3-70b

# Provider Priority Order (comma-separated, from fastest to fallback)
# Recommended: sambanova,cerebras,groq,gemini
AI_PROVIDER_PRIORITY=sambanova,cerebras,groq,gemini


CONTEXT_ENABLED=true
CONTEXT_STORE=memory

# If true and the client does not provide conversation_id,
# the server will create one and return it in response metadata.
CONTEXT_AUTO_CREATE_CONVERSATION=false

# Retrieval behavior
CONTEXT_RECENT_MESSAGES=8
CONTEXT_TOP_K_RELEVANT=6
CONTEXT_MIN_SIMILARITY=0.28

# Token budgets (approximate; uses char-based estimation)
CONTEXT_MAX_PROMPT_TOKENS=8000

# Summarization
CONTEXT_SUMMARY_TRIGGER_TOKENS=10000
CONTEXT_SUMMARY_KEEP_RECENT=10
CONTEXT_SUMMARY_MAX_CHARS=12000

# Embeddings
CONTEXT_EMBEDDING_MODEL=auto
CONTEXT_EMBED_ON_WRITE=true
# Roles to embed (comma-separated). Tip: set to "user" to reduce costs.
CONTEXT_EMBED_ROLES=user,assistant
CONTEXT_EMBED_MAX_CHARS=8000
